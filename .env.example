# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요. (.env 는 커밋되지 않습니다)

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_NAME=AI

# 세션 쿠키 서명용 시크릿. 임의의 긴 문자열로 바꾸세요.
SESSION_SECRET=replace-with-a-long-random-string

# init_db.py 실행 시 시드할 초기 운영자 계정
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
