# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요. (.env 는 커밋되지 않습니다)

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_NAME=AI

# 세션 쿠키 서명용 시크릿. 임의의 긴 문자열로 바꾸세요.
SESSION_SECRET=replace-with-a-long-random-string

# init_db.py 실행 시 시드할 초기 운영자 계정
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me

# ===== 보안검사(스캔) =====
# nmap 실행 파일 경로 (비우면 자동 탐색). 예: C:\Program Files (x86)\Nmap\nmap.exe
NMAP_PATH=
# NVD(CVE) 실시간 조회 (선택)
NVD_API_KEY=
# 사내 프록시 CA 인증서(.pem) 경로 — 지정하면 NVD를 이 CA로 검증
NVD_CA_BUNDLE=
# TLS 검증 생략 (비권장). 뚫어야 할 때만 1
NVD_INSECURE=

# 서버 SSH/DB 자격증명 암호화 키 (Fernet)
# python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())" 로 생성
CRED_KEY=
